<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Life Dashboard</title>
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- React & ReactDOM CDN (안정적인 React 18 버전) -->
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
  
  <!-- Babel CDN (브라우저에서 리액트 코드를 직접 실행할 수 있게 해주는 도구) -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

  <!-- Firebase 핵심 라이브러리 및 서비스 (Compat 버전으로 변경하여 오류 완전 차단) -->
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore-compat.js"></script>

  <style>
    @keyframes spin-slow {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    .animate-spin-slow {
      animation: spin-slow 12s linear infinite;
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans">

  <div id="root"></div>

  <!-- React 앱 실행 스크립트 -->
  <script type="text/babel">
    // --- Firebase 설정 적용 ---
    const firebaseConfig = {
      apiKey: "AIzaSyBiqM4kB8JxbvfwqFTrDv1X4spp9HZK3LE",
      authDomain: "ai-life-deshboard.firebaseapp.com",
      projectId: "ai-life-deshboard",
      storageBucket: "ai-life-deshboard.firebasestorage.app",
      messagingSenderId: "1070435761116",
      appId: "1:1070435761116:web:6ca234df13f08a0477ed19",
      measurementId: "G-H39RS9PPYY"
    };

    // Firebase 초기화 (Compat 글로벌 네임스페이스 사용)
    firebase.initializeApp(firebaseConfig);
    const auth = firebase.auth();
    const db = firebase.firestore();
    
    const appId = 'life-dashboard-app';
    const apiKey = ""; // 런타임에서 자동으로 주입되는 Gemini API Key

    // --- Simple SVG Icons Component ---
    const Icons = {
      Sparkles: () => (
        <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
        </svg>
      ),
      Sun: ({ className }) => (
        <svg className={className} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.364l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
      ),
      Cloud: ({ className }) => (
        <svg className={className} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
        </svg>
      ),
      CloudRain: ({ className }) => (
        <svg className={className} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      ),
      Calendar: () => (
        <svg className="w-5 h-5 mr-1.5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      ),
      CheckSquare: () => (
        <svg className="w-5 h-5 mr-1.5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
      ),
      Clock: ({ className }) => (
        <svg className={className || "w-8 h-8 mx-auto stroke-1 mb-2"} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      ),
      Plus: ({ className }) => (
        <svg className={className || "w-4 h-4"} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 4v16m8-8H4" />
        </svg>
      ),
      Trash2: ({ className }) => (
        <svg className={className || "w-4 h-4"} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      ),
      Check: ({ className }) => (
        <svg className={className} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="3" d="M5 13l4 4L19 7" />
        </svg>
      ),
      LogOut: () => (
        <svg className="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
      )
    };

    function App() {
      const [user, setUser] = React.useState(null);
      const [loading, setLoading] = React.useState(true);
      const [authError, setAuthError] = React.useState(null);
      
      const [todos, setTodos] = React.useState([]);
      const [schedules, setSchedules] = React.useState([]);
      const [ddays, setDdays] = React.useState([]);
      const [weather, setWeather] = React.useState({
        temp: 21,
        condition: 'Sunny',
        location: '충청남도 논산시',
        humidity: 55,
        windSpeed: 3.2
      });
      
      const [customLocation, setCustomLocation] = React.useState('');
      const [newTodo, setNewTodo] = React.useState('');
      const [newSchedule, setNewSchedule] = React.useState({ title: '', date: '', time: '', category: '개인' });
      const [newDday, setNewDday] = React.useState({ title: '', date: '' });
      
      const [aiBriefing, setAiBriefing] = React.useState('정보를 분석 중입니다...');
      const [aiLoading, setAiLoading] = React.useState(false);
      const [currentTime, setCurrentTime] = React.useState(new Date());
      const [activeModal, setActiveModal] = React.useState(null);

      useEffect(() => {
        const timer = setInterval(() => setCurrentTime(new Date()), 60000);
        return () => clearInterval(timer);
      }, []);

      // Google 로그인 인증 관찰자 (Compat API 버전)
      useEffect(() => {
        const unsubscribe = auth.onAuthStateChanged(async (currentUser) => {
          if (currentUser) {
            setUser(currentUser);
            setAuthError(null);
          } else {
            setUser(null);
          }
          setLoading(false);
        });
        return () => unsubscribe();
      }, []);

      const handleGoogleSignIn = async () => {
        setLoading(true);
        setAuthError(null);
        try {
          const provider = new firebase.auth.GoogleAuthProvider();
          await auth.signInWithPopup(provider);
        } catch (error) {
          console.error(error);
          setAuthError('구글 로그인에 실패했습니다. 다시 시도해 주세요.');
          setLoading(false);
        }
      };

      const handleSignOut = async () => {
        await auth.signOut();
        setUser(null);
        setTodos([]);
        setSchedules([]);
        setDdays([]);
      };

      // 실시간 데이터베이스 바인딩 (Compat API 버전)
      useEffect(() => {
        if (!user) return;

        const todosRef = db.collection('artifacts').doc(appId).collection('users').doc(user.uid).collection('todos');
        const unsubscribeTodos = todosRef.onSnapshot((snap) => {
          const list = [];
          snap.forEach(doc => list.push({ id: doc.id, ...doc.data() }));
          setTodos(list.sort((a,b) => b.createdAt - a.createdAt));
        }, (err) => console.error(err));

        const schedulesRef = db.collection('artifacts').doc(appId).collection('users').doc(user.uid).collection('schedules');
        const unsubscribeSchedules = schedulesRef.onSnapshot((snap) => {
          const list = [];
          snap.forEach(doc => list.push({ id: doc.id, ...doc.data() }));
          setSchedules(list.sort((a,b) => new Date(a.date) - new Date(b.date)));
        }, (err) => console.error(err));

        const ddaysRef = db.collection('artifacts').doc(appId).collection('users').doc(user.uid).collection('ddays');
        const unsubscribeDdays = ddaysRef.onSnapshot((snap) => {
          const list = [];
          snap.forEach(doc => list.push({ id: doc.id, ...doc.data() }));
          setDdays(list.sort((a,b) => new Date(a.date) - new Date(b.date)));
        }, (err) => console.error(err));

        return () => {
          unsubscribeTodos();
          unsubscribeSchedules();
          unsubscribeDdays();
        };
      }, [user]);

      const generateAiBriefing = async () => {
        if (!user) return;
        setAiLoading(true);
        
        const uncompletedTodos = todos.filter(t => !t.completed).map(t => t.text).join(', ');
        const activeSchedules = schedules.map(s => `${s.date} ${s.title}`).join(', ');

        const systemPrompt = `당신은 사용자의 스마트 AI 일상 비서입니다. 다정하게 존댓말로 오늘 할일과 일정을 바탕으로 오늘의 격려 메시지와 일상 가이드를 친근한 말투의 문장 3줄로 작성해 주세요.`;
        const userQuery = `할일: ${uncompletedTodos || '없음'}, 일정: ${activeSchedules || '없음'}`;

        const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

        try {
          const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{ parts: [{ text: userQuery }] }],
              systemInstruction: { parts: [{ text: systemPrompt }] }
            })
          });
          const data = await res.json();
          const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
          setAiBriefing(text || "알찬 하루를 가꾸어볼까요? 준비는 모두 끝났습니다.");
        } catch (e) {
          setAiBriefing("오늘의 계획을 점검하고 나만의 특별한 페이스를 이어 나가세요!");
        } finally {
          setAiLoading(false);
        }
      };

      useEffect(() => {
        if (user && (todos.length >= 0 || schedules.length >= 0)) {
          generateAiBriefing();
        }
      }, [user, todos.length, schedules.length]);

      const handleAddTodo = async (e) => {
        e.preventDefault();
        if (!newTodo.trim() || !user) return;
        
        await db.collection('artifacts')
          .doc(appId)
          .collection('users')
          .doc(user.uid)
          .collection('todos')
          .add({
            text: newTodo,
            completed: false,
            createdAt: Date.now()
          });

        setNewTodo('');
        setActiveModal(null);
      };

      const handleToggleTodo = async (id, current) => {
        await db.collection('artifacts')
          .doc(appId)
          .collection('users')
          .doc(user.uid)
          .collection('todos')
          .doc(id)
          .update({
            completed: !current
          });
      };

      const handleDeleteTodo = async (id) => {
        await db.collection('artifacts')
          .doc(appId)
          .collection('users')
          .doc(user.uid)
          .collection('todos')
          .doc(id)
          .delete();
      };

      if (loading) {
        return (
          <div className="min-h-screen bg-slate-50 flex flex-col items-center justify-center">
            <div className="w-12 h-12 border-4 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>
            <p className="text-sm font-medium text-slate-500 mt-4">안전한 로그인을 준비 중입니다...</p>
          </div>
        );
      }

      if (!user) {
        return (
          <div className="min-h-screen bg-gradient-to-tr from-slate-900 to-indigo-950 text-white flex flex-col items-center justify-center px-4">
            <div className="max-w-md w-full text-center space-y-8 bg-white/5 p-8 rounded-3xl border border-white/10 backdrop-blur-md shadow-2xl">
              <div className="flex flex-col items-center space-y-3">
                <div className="bg-indigo-500/20 p-4 rounded-2xl text-indigo-400 border border-indigo-500/30">
                  <Icons.Sparkles />
                </div>
                <h1 className="text-2xl font-extrabold tracking-tight">AI Life Dashboard</h1>
                <p className="text-xs text-slate-400">나만을 위한 스마트 개인 비서 대시보드</p>
              </div>

              <div className="bg-slate-950/40 p-5 rounded-2xl text-left text-xs leading-relaxed space-y-2 border border-white/5">
                <p className="text-amber-400 font-bold">💡 서비스 안내</p>
                <p className="text-slate-300">구글 계정을 연동해 나만의 할 일, 일정 및 날씨 데이터를 안전하게 클라우드에 기록하세요.</p>
              </div>

              {authError && <p className="text-xs text-red-400 font-semibold">{authError}</p>}

              <button
                onClick={handleGoogleSignIn}
                className="w-full flex items-center justify-center space-x-2.5 bg-white text-slate-950 py-3.5 rounded-2xl font-bold text-sm shadow-xl active:scale-95 transition-transform"
              >
                <span>Google 계정으로 로그인</span>
              </button>
            </div>
          </div>
        );
      }

      return (
        <div className="min-h-screen pb-16">
          <header className="bg-white border-b border-slate-100 sticky top-0 z-30">
            <div className="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
              <div className="flex items-center space-x-2">
                <div className="bg-indigo-600 p-2 rounded-xl text-white">
                  <Icons.Sparkles />
                </div>
                <div>
                  <h1 className="text-lg font-bold">AI Life Dashboard</h1>
                  <p className="text-[10px] text-slate-400">스마트 라이프 플래너</p>
                </div>
              </div>
              <div className="flex items-center space-x-3">
                <span className="text-xs bg-slate-100 px-3 py-1.5 rounded-full font-semibold">
                  {user.displayName || user.email}
                </span>
                <button onClick={handleSignOut} className="p-2 hover:bg-slate-100 rounded-lg text-slate-500">
                  <Icons.LogOut />
                </button>
              </div>
            </div>
          </header>

          <main className="max-w-7xl mx-auto px-4 pt-6 space-y-6">
            {/* AI Briefing */}
            <div className="bg-gradient-to-r from-indigo-900 to-slate-900 text-white p-6 rounded-3xl shadow-lg relative overflow-hidden">
              <div className="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div className="space-y-2">
                  <span className="bg-white/10 px-3 py-1 rounded-full text-xs text-amber-300 font-bold">AI 비서 브리핑</span>
                  <p className="text-sm md:text-base leading-relaxed">{aiBriefing}</p>
                </div>
                <button onClick={generateAiBriefing} className="px-4 py-2 bg-white/10 hover:bg-white/20 border border-white/20 rounded-xl text-xs font-bold">
                  새로고침
                </button>
              </div>
            </div>

            {/* Dashboard grid */}
            <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
              {/* To Do Section */}
              <div className="bg-white p-6 rounded-3xl border border-slate-200 shadow-sm">
                <div className="flex justify-between items-center mb-4">
                  <h3 className="font-bold text-slate-800 flex items-center"><Icons.CheckSquare /> 할 일 목록</h3>
                  <button onClick={() => setActiveModal('todo')} className="p-1.5 bg-indigo-50 text-indigo-600 rounded-lg"><Icons.Plus /></button>
                </div>
                <div className="space-y-2 max-h-[250px] overflow-y-auto">
                  {todos.length === 0 ? <p className="text-xs text-slate-400 py-8 text-center">할 일이 없습니다.</p> : 
                    todos.map(t => (
                      <div key={t.id} className="flex items-center justify-between p-3 bg-slate-50 rounded-xl">
                        <div className="flex items-center space-x-3">
                          <button onClick={() => handleToggleTodo(t.id, t.completed)} className={`w-5 h-5 border rounded flex items-center justify-center ${t.completed ? 'bg-indigo-600 border-indigo-600 text-white' : 'bg-white'}`}>
                            {t.completed && <Icons.Check className="w-3 h-3" />}
                          </button>
                          <span className={`text-sm ${t.completed ? 'line-through text-slate-400' : ''}`}>{t.text}</span>
                        </div>
                        <button onClick={() => handleDeleteTodo(t.id)} className="text-slate-300 hover:text-red-500"><Icons.Trash2 /></button>
                      </div>
                    ))
                  }
                </div>
              </div>

              {/* Weather Info Section */}
              <div className="bg-white p-6 rounded-3xl border border-slate-200 shadow-sm flex flex-col justify-between">
                <div>
                  <h3 className="font-bold text-slate-800 mb-4 flex items-center"><Icons.Sun className="w-5 h-5 mr-1.5 text-indigo-600" />기상 및 온도</h3>
                  <div className="flex items-center space-x-4">
                    <Icons.Sun className="w-12 h-12 text-amber-500 animate-spin-slow" />
                    <div>
                      <p className="text-3xl font-extrabold">{weather.temp}°C</p>
                      <p className="text-xs text-slate-500">위치: {weather.location}</p>
                    </div>
                  </div>
                </div>
                <p className="text-[10px] text-slate-400 mt-4">※ 위치 정보에 맞춰 인공지능이 브리핑을 조율합니다.</p>
              </div>
            </div>
          </main>

          {/* Modal */}
          {activeModal === 'todo' && (
            <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
              <div className="bg-white p-6 rounded-3xl max-w-sm w-full space-y-4">
                <h3 className="font-bold text-lg">새 할 일 추가</h3>
                <form onSubmit={handleAddTodo} className="space-y-4">
                  <input 
                    type="text" 
                    value={newTodo} 
                    onChange={e => setNewTodo(e.target.value)} 
                    placeholder="할 일 내용 입력" 
                    required 
                    className="w-full border p-3 rounded-xl text-sm text-slate-800"
                  />
                  <div className="flex space-x-2">
                    <button type="button" onClick={() => setActiveModal(null)} className="flex-1 bg-slate-100 py-2.5 rounded-xl font-bold text-sm">취소</button>
                    <button type="submit" className="flex-1 bg-indigo-600 text-white py-2.5 rounded-xl font-bold text-sm">추가</button>
                  </div>
                </form>
              </div>
            </div>
          )}
        </div>
      );
    }

    const container = document.getElementById('root');
    const root = ReactDOM.createRoot(container);
    root.render(<App />);
  </script>
</body>
</html>
